SELECT * FROM Products;

SELECT *
FROM
(
    SELECT ProductID,
           ProductName,
           Category,
           Price,
           ROW_NUMBER() OVER
           (
               PARTITION BY Category
               ORDER BY Price DESC
           ) AS Row_Number
    FROM Products
) AS RankedProducts
WHERE Row_Number <= 3;

SELECT *
FROM
(
    SELECT ProductID,
           ProductName,
           Category,
           Price,
           RANK() OVER
           (
               PARTITION BY Category
               ORDER BY Price DESC
           ) AS Rank_No
    FROM Products
) AS RankedProducts
WHERE Rank_No <= 3;

SELECT *
FROM
(
    SELECT ProductID,
           ProductName,
           Category,
           Price,
           DENSE_RANK() OVER
           (
               PARTITION BY Category
               ORDER BY Price DESC
           ) AS Dense_Rank
    FROM Products
) AS RankedProducts
WHERE Dense_Rank <= 3;
